{
  "manifest_version": 3,
  "name": "Sainsbury's Nutrition Hints",
  "version": "0.1.0",
  "key": "",
  "description": "Shows nutrition info overlays and protein value sorting on Sainsbury's grocery pages",
  "permissions": ["storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nutrition Hints"
  },
  "host_permissions": ["*://*.sainsburys.co.uk/*"],
  "content_scripts": [
    {
      "matches": ["*://*.sainsburys.co.uk/gol-ui/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
