{
  "name": "sainsburys-scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx src/main.tsx",
    "scrape:discover": "tsx src/main.tsx --discovery-only",
    "scrape:detail": "tsx src/main.tsx --detail-only",
    "scrape:reparse": "tsx src/main.tsx --reparse",
    "scrape:dry": "tsx src/main.tsx --dry-run",
    "export": "tsx src/main.tsx --export"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.2.0",
    "ink": "^6.0.0",
    "puppeteer-core": "^24.37.5",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
